# ZukoLabs VTO — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to version control.

# ─── Meta WhatsApp Cloud API ─────────────────────────────────
WHATSAPP_TOKEN=                    # Bearer token for sending messages
WHATSAPP_VERIFY_TOKEN=             # Webhook verification token (you choose this)
WHATSAPP_APP_SECRET=               # For HMAC signature verification

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=                      # https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=              # Service role key (server-side only, NEVER expose)
SUPABASE_ANON_KEY=                 # For public-facing operations

# ─── Groq ────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Replicate (Try-On Engine) ───────────────────────────────
REPLICATE_API_TOKEN=
REPLICATE_VITON_MODEL=cuuupid/idm-vton

# ─── Voice Transcription ─────────────────────────────────────
# Using Groq (whisper-large-v3) via GROQ_API_KEY

# ─── App Settings ────────────────────────────────────────────
APP_ENV=development                # production | development
BASE_URL=                          # Your Render.com URL (e.g. https://zukolabs-vto.onrender.com)
LOG_LEVEL=INFO
